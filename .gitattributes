# Normalize all text to LF in the repo; check out LF (Cloud Run is Linux).
* text=auto eol=lf

# Windows-only scripts keep CRLF.
*.bat   text eol=crlf
*.ps1   text eol=crlf
*.cmd   text eol=crlf

# Binaries — never touch.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.woff  binary
*.woff2 binary
